# Required in production. If unset, a secret is generated and stored at <DATABASE_PATH dir>/.secret (mode 0600).
APP_SECRET=

# Auth
ENABLE_SIGNUP=true
ENABLE_PASSWORD_LOGIN=true
AUTO_PROMOTE_FIRST_USER=true

# OIDC (optional). OIDC_ONLY=true disables password login + sign-up.
#OIDC_ONLY=false
#OIDC_ISSUER=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_SCOPES=openid profile email


# Agents / memory
AGENT_MAX_STEPS=25
MAX_ATTACHMENT_SIZE_MB=50

TZ=Europe/Berlin
#ORIGIN=https://chat.example.com
