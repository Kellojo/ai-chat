# Required in production. If unset, a secret is generated and stored at <DATABASE_PATH dir>/.secret (mode 0600).
APP_SECRET=

# Auth
ENABLE_SIGNUP=true
ENABLE_PASSWORD_LOGIN=true
AUTO_PROMOTE_FIRST_USER=true

# OIDC (optional). OIDC_ONLY=true disables password login + sign-up.
OIDC_ONLY=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email

# Volumes (docker-compose sets these to /data, /memory, /documents, /workspaces)
DATABASE_PATH=./data/ai-chat.db
MEMORY_VOLUME=./memory
DOCUMENTS_VOLUME=./documents
WORKSPACES_VOLUME=./workspaces
WORKSPACE_GC_DAYS=30

# Agents / memory
AGENT_MAX_STEPS=25
MEMORY_EXTRACT_SCHEDULE=*/15 * * * *
MAX_ATTACHMENT_SIZE_MB=50

# MCP
# Allow the bundled settings MCP server to write global settings (admin callers only).
SETTINGS_MCP_WRITE=false

# Providers
LM_STUDIO_BASE_URL=http://localhost:1234

# Security
# (no SSRF guard: webfetch may reach private/LAN addresses by design)

TZ=Europe/Berlin
PORT=3000
# ORIGIN=https://chat.example.com
